NODE_ENV=development
PORT=3000
LOG_LEVEL=info

BOT_ENABLED=true
BOT_APP_ID=00000000-0000-0000-0000-000000000000
BOT_DISPLAY_NAME="Meeting Recorder"
BOT_CALLBACK_URL=https://your-public-api.example.com/webhooks/teams/calls
BOT_REQUESTED_MODALITIES=audio
BOT_SUPPORTS_VIDEO=false
BOT_ALLOW_CONVERSATION_WITHOUT_HOST=true

TEAMS_APP_ID=00000000-0000-0000-0000-000000000000
TEAMS_APP_SHORT_NAME="Meeting Recorder"
TEAMS_APP_FULL_NAME="Meeting Recorder Bot"
TEAMS_APP_SHORT_DESCRIPTION="Join Teams meetings, then let backend services ingest recordings and transcripts."
TEAMS_APP_FULL_DESCRIPTION="Meeting Recorder joins supported Teams meetings, can be removed by organizers from the participant roster, and works with the backend ingestion service to collect transcripts and recordings after Graph publishes them."
TEAMS_APP_DEVELOPER_NAME="Your Company"
TEAMS_APP_WEBSITE_URL=https://your-public-api.example.com
TEAMS_APP_PRIVACY_URL=https://your-public-api.example.com/privacy
TEAMS_APP_TERMS_URL=https://your-public-api.example.com/terms

AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=replace-me
AZURE_USE_MANAGED_IDENTITY=false
AZURE_MANAGED_IDENTITY_CLIENT_ID=
AZURE_CLIENT_CERTIFICATE_PATH=
AZURE_CLIENT_CERTIFICATE_PASSWORD=

GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
GRAPH_SCOPE=https://graph.microsoft.com/.default
GRAPH_NOTIFICATION_URL=https://your-public-api.example.com/webhooks/graph
GRAPH_LIFECYCLE_NOTIFICATION_URL=https://your-public-api.example.com/webhooks/graph/lifecycle
GRAPH_NOTIFICATION_CLIENT_STATE=replace-with-long-random-secret
GRAPH_SUBSCRIPTION_MODE=tenant
GRAPH_ORGANIZER_USER_IDS=
GRAPH_INCLUDE_RESOURCE_DATA=true
GRAPH_SUBSCRIPTION_TTL_MINUTES=1440
GRAPH_SUBSCRIPTION_RENEWAL_WINDOW_MINUTES=180
GRAPH_SUBSCRIPTION_SYNC_INTERVAL_MS=900000
GRAPH_ENCRYPTION_CERTIFICATE_PATH=./certs/graph-notification-public.pem
GRAPH_ENCRYPTION_PRIVATE_KEY_PATH=./certs/graph-notification-private.pem
GRAPH_ENCRYPTION_PRIVATE_KEY_PASSPHRASE=
GRAPH_ENCRYPTION_CERTIFICATE_ID=teams-recordings-webhook-cert

AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
AZURE_BLOB_CONTAINER_ARTIFACTS=teams-artifacts
AZURE_BLOB_CONTAINER_STATE=teams-state
AZURE_BLOB_CONTAINER_DEADLETTER=teams-deadletter

QUEUE_MODE=memory
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SERVICE_BUS_INGESTION_QUEUE=teams-artifact-ingestion
AZURE_SERVICE_BUS_COMPLIANCE_QUEUE=teams-meeting-compliance
AZURE_SERVICE_BUS_EVENT_QUEUE=teams-artifact-events
QUEUE_MAX_DELIVERIES=10

INGESTION_MAX_FETCH_ATTEMPTS=6
INGESTION_INITIAL_RETRY_DELAY_MS=3000
INGESTION_LOCK_TTL_SECONDS=900
INGESTION_WORKER_CONCURRENCY=4

COMPLIANCE_ENABLED=true
COMPLIANCE_DEFAULT_EXPECT_RECORDING=true
COMPLIANCE_DEFAULT_EXPECT_TRANSCRIPT=true
COMPLIANCE_DEFAULT_GRACE_PERIOD_MINUTES=30
COMPLIANCE_REMINDER_INTERVAL_MINUTES=30
COMPLIANCE_MAX_REMINDERS=3
COMPLIANCE_WORKER_CONCURRENCY=2
COMPLIANCE_NOTIFICATION_WEBHOOK_URL=
