# Sample environment variables for local development
# Copy this file to `.env` and fill the values before running locally.

# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Azure identity (provide client secret OR certificate OR enable managed identity)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
# Uncomment one of the following depending on your auth method
# AZURE_CLIENT_SECRET=
# AZURE_CLIENT_CERTIFICATE_PATH=/path/to/cert.pfx
# AZURE_CLIENT_CERTIFICATE_PASSWORD=your-password
AZURE_USE_MANAGED_IDENTITY=false
AZURE_MANAGED_IDENTITY_CLIENT_ID=

# Microsoft Graph notification endpoints (public HTTPS)
GRAPH_NOTIFICATION_URL=https://your-public-url.example.com/webhook/notifications
GRAPH_LIFECYCLE_NOTIFICATION_URL=https://your-public-url.example.com/webhook/notification-lifecycle
GRAPH_NOTIFICATION_CLIENT_STATE=change-me-with-16+chars

# Storage
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER_ARTIFACTS=teams-artifacts
AZURE_BLOB_CONTAINER_STATE=teams-state

# Queue (memory by default; set to servicebus to use Azure Service Bus)
QUEUE_MODE=memory
# AZURE_SERVICE_BUS_CONNECTION_STRING=

# Bot (optional)
BOT_ENABLED=true
BOT_APP_ID=
BOT_CALLBACK_URL=https://your-public-url.example.com/bot/callback

# Optional: adjust worker/ingestion tuning
INGESTION_WORKER_CONCURRENCY=4
COMPLIANCE_ENABLED=true

# SECURITY: never commit secrets. Use Key Vault or your cloud provider secret store in production.
