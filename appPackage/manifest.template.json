{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.24/MicrosoftTeams.schema.json",
  "manifestVersion": "1.24",
  "version": "1.0.0",
  "id": "__TEAMS_APP_ID__",
  "packageName": "com.example.meetingrecorder",
  "developer": {
    "name": "__TEAMS_APP_DEVELOPER_NAME__",
    "websiteUrl": "__TEAMS_APP_WEBSITE_URL__",
    "privacyUrl": "__TEAMS_APP_PRIVACY_URL__",
    "termsOfUseUrl": "__TEAMS_APP_TERMS_URL__"
  },
  "name": {
    "short": "__TEAMS_APP_SHORT_NAME__",
    "full": "__TEAMS_APP_FULL_NAME__"
  },
  "description": {
    "short": "__TEAMS_APP_SHORT_DESCRIPTION__",
    "full": "__TEAMS_APP_FULL_DESCRIPTION__"
  },
  "accentColor": "#0F6CBD",
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "bots": [
    {
      "botId": "__BOT_APP_ID__",
      "scopes": ["personal", "groupChat", "team"],
      "supportsCalling": true,
      "supportsVideo": __BOT_SUPPORTS_VIDEO__,
      "isNotificationOnly": false
    }
  ],
  "permissions": ["identity"],
  "validDomains": ["__VALID_DOMAIN__"]
}
